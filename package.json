{
  "name": "theme-school",
  "version": "0.1.0",
  "description": "A disposable visual learning school for designing standalone Obsidian themes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "check": "tsc -noEmit -skipLibCheck"
  },
  "keywords": ["obsidian", "theme", "css", "visual-editor", "learning"],
  "author": "Michelle G Dyason",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.8.0"
  }
}
