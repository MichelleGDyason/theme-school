{
  "name": "theme-school",
  "version": "0.1.2",
  "description": "A disposable visual learning school for designing standalone Obsidian themes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "check": "tsc -noEmit -skipLibCheck",
    "lint": "eslint src --max-warnings=0"
  },
  "keywords": [
    "obsidian",
    "theme",
    "css",
    "visual-editor",
    "learning"
  ],
  "author": "Michelle G Dyason",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@eslint/json": "^0.14.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "latest",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.65.0"
  }
}
